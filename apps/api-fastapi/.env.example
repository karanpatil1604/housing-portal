# ============================================================
#  Housing Price API — environment variable reference
#  Copy this file to .env and adjust values as needed.
#  Never commit a populated .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Housing Price Prediction API"
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1                        # increase for production (1 per CPU core)

# ── Model ─────────────────────────────────────────────────────
MODEL_DIR=models                 # directory where the .joblib artefact is saved
MODEL_FILENAME=housing_price_model.joblib
TRAINING_DATA_PATH=data/House_Price_Dataset.csv
RETRAIN_ON_STARTUP=true          # set to false to always load from MODEL_DIR

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console               # console (dev) | json (production)

# ── Batch limits ──────────────────────────────────────────────
MAX_BATCH_SIZE=500               # maximum properties per /predict/batch call
