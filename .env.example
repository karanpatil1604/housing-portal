# ============================================================
# Housing Portal — Master Environment File
# Copy to .env before running:  cp .env.example .env
#
# ONE COMMAND DEMO:
#   docker compose up --build
# ============================================================

# ── Ports (change if anything clashes on your machine) ──────
FASTAPI_PORT=8000
JAVA_API_PORT=8080
WEB_PORT=3000

# ── Internal service URLs (used by containers to talk to each other)
# These use Docker service DNS names — do NOT change
FASTAPI_INTERNAL_URL=http://fastapi:8000
JAVA_API_INTERNAL_URL=http://api-java:8080

# ── Public URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# ── Java API ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://127.0.0.1:3000
SPRING_PROFILES_ACTIVE=docker

# ── FastAPI (adjust to match your app's actual env vars) ────
ENVIRONMENT=development
